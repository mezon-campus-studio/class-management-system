DB_URL=jdbc:postgresql://localhost:5432/classroomhub
DB_USERNAME=classroomhub_user
DB_PASSWORD=classroomhub_pass

# Generate with: openssl rand -base64 64
JWT_SECRET=your_256bit_base64_secret_here

PORT=8080
UPLOAD_DIR=uploads

# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Gmail (2FA): MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_PASSWORD = App Password (16 chars)
# AWS SES:     MAIL_HOST=email-smtp.<region>.amazonaws.com, MAIL_PORT=587, credentials from SES console
# Port 465 (SSL): set MAIL_SSL=true, MAIL_STARTTLS=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_or_ses_smtp_password
# MAIL_SSL=false
# MAIL_STARTTLS=true
